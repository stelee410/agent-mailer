#!/usr/bin/env bash
# start-team.sh — smart launcher for an Agent Mailer team.
# Generated by the zudui skill. Auto-detects tmux > iTerm2 > manual.
#
# Override:
#   TEAM_LAUNCHER=tmux|iterm|manual ./start-team.sh
#   TEAM_SESSION=foo ./start-team.sh

set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# auto-load .env (created by /zudui)
if [[ -f "$DIR/.env" ]]; then
  set -a; source "$DIR/.env"; set +a
fi

[[ -n "${AMP_API_KEY:-}" ]] || { echo "✗ AMP_API_KEY 缺失 — 检查 $DIR/.env 或 export"; exit 1; }
command -v claude >/dev/null || { echo "✗ claude CLI 未安装"; exit 1; }

# discover agents (subdirs containing AGENT.md)
ROLES=()
for d in "$DIR"/*/; do
  [[ -f "$d/AGENT.md" ]] && ROLES+=("$(basename "$d")")
done
[[ ${#ROLES[@]} -gt 0 ]] || { echo "✗ 没找到任何 <子目录>/AGENT.md — 先在母目录跑 /zudui"; exit 1; }

SESSION="${TEAM_SESSION:-agent-team}"
LAUNCHER="${TEAM_LAUNCHER:-auto}"

# auto-detect launcher
if [[ "$LAUNCHER" == "auto" ]]; then
  if command -v tmux >/dev/null; then
    LAUNCHER=tmux
  elif [[ "$OSTYPE" == darwin* ]] && osascript -e 'tell app "iTerm" to version' >/dev/null 2>&1; then
    LAUNCHER=iterm
  else
    LAUNCHER=manual
  fi
fi

# Pre-accept Claude Code's workspace-trust dialog for each agent dir by writing
# `hasTrustDialogAccepted: true` into ~/.claude.json. Without this, every fresh
# `claude` boot in a new dir blocks on "Trust this folder?", which an autonomous
# agent can't respond to. (The flag --dangerously-skip-permissions does NOT cover
# this — trust is a separate gate.)
pre_trust_dirs() {
  local cfg="$HOME/.claude.json"
  [[ -f "$cfg" ]] || return 0
  command -v python3 >/dev/null || { echo "⚠ python3 缺失,跳过 trust 预批准 — trust dialog 会出现"; return 0; }
  python3 - "$cfg" "$DIR" "${ROLES[@]}" <<'PY'
import json, sys
cfg, parent, *roles = sys.argv[1:]
with open(cfg) as f: d = json.load(f)
proj = d.setdefault("projects", {})
for path in [parent] + [f"{parent}/{r}" for r in roles]:
    e = proj.setdefault(path, {})
    if not e.get("hasTrustDialogAccepted"):
        e["hasTrustDialogAccepted"] = True
with open(cfg, "w") as f: json.dump(d, f, indent=2)
PY
}

# Dismiss the "bypass permissions mode" warning dialog that
# --dangerously-skip-permissions triggers on every boot (this acceptance is
# session-only — Claude Code doesn't persist it). Only press "2" (= "Yes, I
# accept") on panes that actually show the dialog, and only once per pane,
# otherwise the digit becomes a stray char in claude's input buffer.
dismiss_bypass_dialogs() {
  echo "→ dismissing bypass-permissions dialogs..."
  local sent="" try i
  for try in 1 2 3 4 5 6; do
    sleep 2
    for i in "${!ROLES[@]}"; do
      [[ ",$sent," == *",$i,"* ]] && continue
      if tmux capture-pane -t "$SESSION:team.$i" -p 2>/dev/null | grep -q "Yes, I accept"; then
        tmux send-keys -t "$SESSION:team.$i" '2'
        sent="$sent,$i"
      fi
    done
  done
}

launch_tmux() {
  if tmux has-session -t "$SESSION" 2>/dev/null; then
    echo "→ tmux session '$SESSION' 已存在,attach 中..."
    exec tmux attach -t "$SESSION"
  fi

  pre_trust_dirs

  tmux new-session -d -s "$SESSION" -n team \
       -e "AMP_API_KEY=$AMP_API_KEY" \
       -e "AMP_BROKER_URL=${AMP_BROKER_URL:-}" \
       -c "$DIR/${ROLES[0]}"

  local r i
  for r in "${ROLES[@]:1}"; do
    tmux split-window -t "$SESSION:team" \
         -e "AMP_API_KEY=$AMP_API_KEY" \
         -e "AMP_BROKER_URL=${AMP_BROKER_URL:-}" \
         -c "$DIR/$r"
    tmux select-layout -t "$SESSION:team" tiled
  done

  tmux set-window-option -t "$SESSION:team" pane-border-status top
  tmux set-window-option -t "$SESSION:team" synchronize-panes off

  for i in "${!ROLES[@]}"; do
    tmux select-pane -t "$SESSION:team.$i" -T " ${ROLES[$i]} "
  done
  # --dangerously-skip-permissions: autonomous agents can't respond to tool prompts
  for i in "${!ROLES[@]}"; do
    tmux send-keys -t "$SESSION:team.$i" 'claude --dangerously-skip-permissions "上班"' C-m
  done

  dismiss_bypass_dialogs

  tmux select-layout -t "$SESSION:team" tiled
  exec tmux attach -t "$SESSION"
}

launch_iterm() {
  pre_trust_dirs
  {
    echo 'tell application "iTerm"'
    echo '  activate'
    echo '  create window with default profile'
    printf '  tell current session of current window to write text "cd %q && source %q && claude --dangerously-skip-permissions '\''上班'\''"\n' \
           "$DIR/${ROLES[0]}" "$DIR/.env"
    local i
    for ((i=1; i<${#ROLES[@]}; i++)); do
      echo '  tell current window'
      echo '    set newSplit to (split vertically with default profile)'
      printf '    tell newSplit to write text "cd %q && source %q && claude --dangerously-skip-permissions '\''上班'\''"\n' \
             "$DIR/${ROLES[$i]}" "$DIR/.env"
      echo '  end tell'
    done
    echo 'end tell'
  } | osascript -
  echo "→ iTerm 模式: 每个 pane 第一次启动会出 'Bypass permissions' 警告,按 2 选 'Yes, I accept' 即可 (trust 已预批准)。"
}

launch_manual() {
  pre_trust_dirs
  echo "未自动检测到 tmux 或 iTerm2。请打开 ${#ROLES[@]} 个终端,各自执行:"
  echo
  local r
  for r in "${ROLES[@]}"; do
    printf '  cd %q && source %q && claude --dangerously-skip-permissions '\''上班'\''\n' "$DIR/$r" "$DIR/.env"
  done
  echo
  echo "(每个 pane 启动后,在 'Bypass permissions' 警告里按 2 选 'Yes, I accept'。Trust 已预批准。)"
  echo "(装 tmux 后自动模式: TEAM_LAUNCHER=tmux ./start-team.sh)"
}

case "$LAUNCHER" in
  tmux)   launch_tmux ;;
  iterm)  launch_iterm ;;
  manual) launch_manual ;;
  *) echo "✗ 未知 TEAM_LAUNCHER: $LAUNCHER (合法值: tmux | iterm | manual | auto)"; exit 2 ;;
esac
